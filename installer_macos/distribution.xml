<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Imaginify</title>
    <organization>com.jezweb</organization>

    <welcome    file="welcome.html"    mime-type="text/html"/>
    <license    file="LICENSE.txt"     mime-type="text/plain"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>

    <options customize="never" allow-external-scripts="no" rootVolumeOnly="true"/>
    <domains enable_anywhere="false" enable_currentUserHome="false" enable_localSystem="true"/>

    <pkg-ref id="com.jezweb.imaginify"
             version="1.0.0"
             auth="root">Imaginify-component.pkg</pkg-ref>

    <choices-outline>
        <line choice="default">
            <line choice="com.jezweb.imaginify"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.jezweb.imaginify" visible="false">
        <pkg-ref id="com.jezweb.imaginify"/>
    </choice>
</installer-gui-script>
